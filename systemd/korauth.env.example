# korauth systemd environment file
# Copy to /etc/korauth/korauth.env and configure

# PostgreSQL (required)
DATABASE_URL=postgres://openkor:changeme@localhost:5432/openkor?sslmode=disable

# Redis (required)
REDIS_URL=redis://localhost:6379/0

# JWT Keys (required)
# Keys should be owned by korauth user with 0600 permissions
JWT_PRIVATE_KEY_PATH=/etc/korauth/keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=/etc/korauth/keys/jwt-public.pem

# JWT Configuration
JWT_ISSUER=openkor-auth
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h

# Initial Seed (admin user created on first startup)
SEED_TENANT_NAME=default
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=changeme

# Logging
LOG_LEVEL=info

# Server
HTTP_PORT=8081
SERVICE_NAME=korauth
DB_SCHEMA=auth
