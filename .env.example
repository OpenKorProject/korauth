# korauth — Identity / IAM service
SERVICE_NAME=korauth
HTTP_PORT=8081

# PostgreSQL (auth schema)
DATABASE_URL=postgres://openkor:changeme@localhost:5432/openkor?sslmode=disable
DB_SCHEMA=auth

# Redis (refresh token store + brute-force counters)
REDIS_URL=redis://localhost:6379/0

# JWT (RS256) — do not put keys in repo, mount them / use secret manager
JWT_PRIVATE_KEY_PATH=/etc/openkor/keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=/etc/openkor/keys/jwt-public.pem
JWT_ISSUER=openkor-auth
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h

# Initial startup seed tenant + admin (in prod, password change is required on first login)
SEED_TENANT_NAME=default
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=changeme

LOG_LEVEL=info
